{
  "name": "rendel",
  "version": "0.1.0",
  "description": "Headless Strudel pattern renderer — export .js pattern files to WAV/MP3 from the command line",
  "main": "src/cli.js",
  "bin": {
    "rendel": "src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "serve": "node api/server.js",
    "test": "vitest",
    "lint": "biome ci .",
    "format": "biome check --write .",
    "prepare": "husky",
    "postinstall": "node scripts/patch-kabelsalat.cjs && patch-package"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,json}": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyote4094/rendel.git"
  },
  "keywords": [
    "strudel",
    "audio",
    "renderer",
    "cli",
    "wav",
    "mp3"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/wyote4094/rendel/issues"
  },
  "homepage": "https://github.com/wyote4094/rendel#readme",
  "dependencies": {
    "@strudel/core": "^1.2.6",
    "@strudel/mini": "^1.2.6",
    "@strudel/soundfonts": "^1.3.0",
    "@strudel/tonal": "^1.2.6",
    "@strudel/transpiler": "^1.2.6",
    "@strudel/webaudio": "^1.3.0",
    "commander": "^14.0.3",
    "express": "^4.21.2",
    "fuse.js": "^7.1.0",
    "node-web-audio-api": "^1.0.9",
    "patch-package": "^8.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "vitest": "^4.1.7"
  }
}
