{
  "name": "rendel",
  "version": "0.1.0",
  "description": "Headless Strudel pattern renderer — export .js pattern files to WAV/MP3 from the command line",
  "main": "src/cli.js",
  "bin": {
    "rendel": "src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "test": "vitest",
    "postinstall": "patch-package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyote4094/rendel.git"
  },
  "keywords": [
    "strudel",
    "audio",
    "renderer",
    "cli",
    "wav",
    "mp3"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/wyote4094/rendel/issues"
  },
  "homepage": "https://github.com/wyote4094/rendel#readme",
  "dependencies": {
    "@strudel/core": "^1.2.6",
    "@strudel/mini": "^1.2.6",
    "@strudel/soundfonts": "^1.3.0",
    "@strudel/tonal": "^1.2.6",
    "@strudel/transpiler": "^1.2.6",
    "@strudel/webaudio": "^1.3.0",
    "commander": "^14.0.3",
    "node-web-audio-api": "^1.0.9"
  },
  "devDependencies": {
    "patch-package": "^8.0.1",
    "vitest": "^4.1.7"
  }
}
